{
  "name": "tiger-tennis",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:frontend": "cd apps/frontend && taro build --type h5 --watch",
    "build:frontend": "cd apps/frontend && taro build --type h5",
    "build:weapp": "cd apps/frontend && taro build --type weapp"
  },
  "dependencies": {
    "@tarojs/plugin-framework-react": "^4.2.0",
    "@tarojs/plugin-platform-h5": "^4.2.0"
  }
}

